@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject UserManager<Project_smarties.Models.UserApplicationData> UserDataManager
@inject Project_smarties.Data.ApplicationDbContext DbContext

@{
    var userdata = await UserDataManager.GetUserAsync(User);
    //var teamdata = await TeamDataManager.FindByNameAsync(userdata.TeamName);

}

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <p>your id is @userdata?.Id</p>
    <!--- check if the user is an admin or regular user --->
    @if(User.IsInRole("admin"))
        {
            <p>welcome aboard captain</p>
        }
    @if (User.IsInRole("user"))
        {
            <p>welcome plep</p>
        }
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">

                @userdata?.Name
            </a>
        <ul class="dropdown-menu">
                <li class="nav-item">
                    <a class="dropdown-item"  asp-page="/UserProfile">
                        <form class="form-inline" asp-page="/UserProfile" method="get">
                            <!-- sends the userId to the profile page in the link-->
                            <button type="submit" class="nav-link btn btn-link text-dark"
                                    name="UserId"
                                    value="@userdata?.Id">
                                    Profile
                            </button>
                        </form>
                    </a>
                </li>
            <li class="nav-item">
                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Manage/Index" method="get">
                            <button type="submit" class="nav-link btn btn-link text-dark">account details</button>
                        </form>
                </a>
            </li>
                <!---- line devider ---->
                <li><hr class="dropdown-divider" /></li>
                <!---- line devider ---->
            
                @if (User.IsInRole("admin"))
                {
                    /*
                    <!---- line devider ---->
                    <li><hr class="dropdown-divider" /></li>
                    <!---- line devider ---->
                    <li class="dropdown-item-text">admin actions</li>
                    <!---- link to match verification ---->
                    <li class="nav-item">
                        <a class="nav-link btn btn-link text-dark dropdown-item" asp-page="/MatchVerificaiton/Index">Match verification</a>  
                    </li>

                    <li class="nav-item">
                        <a class="nav-link btn btn-link text-dark dropdown-item" asp-page="/Events/Approval">Event approval</a>
                    </li>
                    */
                }

            <li><hr class="dropdown-divider"/></li>
            <li>
                <a class="dropdown-item"  asp-page="/Acount/Logout">
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
                        </form>
                    </a>
            </li>

        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">sign up</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
